---
layout: default
---

<h2>Latest Posts</h2>

<div class="post-list">
  {% for post in site.posts %}
    <article class="post-card">
      <h3>
        <a href="{{ post.url }}">{{ post.title }}</a>
      </h3>
      <small>{{ post.date | date: "%B %d, %Y" }}</small>
      <p>{{ post.excerpt }}</p>
    </article>
  {% endfor %}
</div>
